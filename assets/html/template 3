<!DOCTYPE html>
<html>
<head>
<style>
body {
    font-family: 'Segoe UI', sans-serif;
    margin: 40px;
    color: #222;
}

h1 {
    text-align: center;
    letter-spacing: 1px;
}

.contact {
    text-align: center;
    font-size: 13px;
    margin-bottom: 20px;
    color: #555;
}

.section {
    margin-top: 25px;
}

.section h2 {
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #444;
    margin-bottom: 8px;
}

.line {
    height: 1px;
    background: #ccc;
    margin-bottom: 10px;
}

p {
    font-size: 14px;
    line-height: 1.6;
}
</style>
</head>

<body>

<h1>{{ full_name }}</h1>

<div class="contact">
    {{ email }} | {{ phone }} | {{ linkedin }} | {{ github }} | {{ address }}
</div>

<div class="section">
    <h2>Summary</h2>
    <div class="line"></div>
    <p>{{ summary }}</p>
</div>

<div class="section">
    <h2>Education</h2>
    <div class="line"></div>
    <p>{{ education }}</p>
</div>

<div class="section">
    <h2>Skills</h2>
    <div class="line"></div>
    <p>{{ skills }}</p>
</div>

<div class="section">
    <h2>Projects</h2>
    <div class="line"></div>
    <p>{{ projects }}</p>
</div>

<div class="section">
    <h2>Experience</h2>
    <div class="line"></div>
    <p>{{ experience }}</p>
</div>

<div class="section">
    <h2>Certifications</h2>
    <div class="line"></div>
    <p>{{ certifications }}</p>
</div>

<div class="section">
    <h2>Achievements</h2>
    <div class="line"></div>
    <p>{{ achievements }}</p>
</div>

</body>
</html>
