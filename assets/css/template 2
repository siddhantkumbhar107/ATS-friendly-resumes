<!DOCTYPE html>
<html>
<head>
<style>
body {
    font-family: Arial;
    margin: 0;
    display: flex;
}

.sidebar {
    width: 30%;
    background: #1e3a5f;
    color: white;
    padding: 30px;
}

.main {
    width: 70%;
    padding: 30px;
}

h1 {
    margin-bottom: 5px;
}

.section {
    margin-top: 20px;
}

.section h2 {
    border-bottom: 2px solid #1e3a5f;
    padding-bottom: 5px;
}

p {
    font-size: 14px;
    line-height: 1.6;
}
</style>
</head>

<body>

<div class="sidebar">
    <h1>{{ full_name }}</h1>
    <p>{{ email }}</p>
    <p>{{ phone }}</p>
    <p>{{ linkedin }}</p>
    <p>{{ github }}</p>
    <p>{{ address }}</p>

    <div class="section">
        <h2>Skills</h2>
        <p>{{ skills }}</p>
    </div>

    <div class="section">
        <h2>Certifications</h2>
        <p>{{ certifications }}</p>
    </div>
</div>

<div class="main">
    <div class="section">
        <h2>Professional Summary</h2>
        <p>{{ summary }}</p>
    </div>

    <div class="section">
        <h2>Education</h2>
        <p>{{ education }}</p>
    </div>

    <div class="section">
        <h2>Projects</h2>
        <p>{{ projects }}</p>
    </div>

    <div class="section">
        <h2>Experience</h2>
        <p>{{ experience }}</p>
    </div>

    <div class="section">
        <h2>Achievements</h2>
        <p>{{ achievements }}</p>
    </div>
</div>

</body>
</html>
